"use client";

import { motion } from "framer-motion";

export default function Home() {
  return (
    <main style=3D{{ padding: "20px" }}>

      {/* HEADER */}
      <header style=3D{{ display: "flex", justifyContent: "space-between",
marginBottom: "60px" }}>
        <h1 style=3D{{ color: "#D4AF37" }}>GORGEOUS CANDLES</h1>
      </header>

      {/* HERO */}
      <section style=3D{{ textAlign: "center", marginBottom: "80px" }}>
        <motion.h2 initial=3D{{ opacity: 0 }} animate=3D{{ opacity: 1 }}
style=3D{{ fontSize: "48px" }}>
          Where Elegance Meets Glow
        </motion.h2>
        <p>100% Coconut Soy Wax =E2=80=A2 Clean Burn =E2=80=A2 Luxury Exper=
ience</p>
        <button style=3D{{ background: "#D4AF37", padding: "12px 24px",
border: "none" }}>
          Shop Collection
        </button>
      </section>

      {/* CLEAN LUXURY */}
      <section style=3D{{ marginBottom: "60px" }}>
        <h2>Clean Luxury. Elevated Glow.</h2>
        <p>
          Crafted with 100% coconut soy wax for a cleaner, longer-lasting
burn and a smooth,
          luxurious finish.
        </p>
      </section>

      {/* PRODUCTS */}
      <section style=3D{{ marginBottom: "60px" }}>
        <h2>Signature Collection</h2>
        <div style=3D{{ display: "flex", gap: "20px" }}>
          {["Your Candle 1", "Your Candle 2", "Your Candle 3"].map((item,
i) =3D> (
            <div key=3D{i} style=3D{{ border: "1px solid #333", padding: "2=
0px"
}}>
              <div style=3D{{ height: "150px", background: "#222" }} />
              <h3>{item}</h3>
              <p>$30</p>
            </div>
          ))}
        </div>
      </section>

      {/* WHY */}
      <section style=3D{{ marginBottom: "60px" }}>
        <h2>Why Choose Gorgeous Candles</h2>
        <ul>
          <li>100% coconut soy wax</li>
          <li>Clean burn</li>
          <li>Luxury fragrance</li>
        </ul>
      </section>

      {/* CTA */}
      <section style=3D{{ textAlign: "center" }}>
        <h2>Experience the Glow</h2>
        <button style=3D{{ background: "#D4AF37", padding: "12px 24px",
border: "none" }}>
          Shop Now
        </button>
      </section>

    </main>
  );
}

